# 复制为 .env 后由 docker-compose 或本地加载（切勿提交真实密钥）

SECRET_KEY=请使用足够长度的随机字符串

# 容器内 SQLite 路径（默认即可）
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# NAS 挂载到容器内的根路径（与 docker-compose 卷映射一致）
MOUNT_PATH=/data

# OpenAI 兼容 API（可指向自建网关）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 可选：自然语言重命名说明（数据库配置为空时使用）
RENAME_INSTRUCTION=

# 浏览器访问来源（公网域名或反代地址，多个用英文逗号分隔）
CORS_ORIGINS=http://localhost:8000,https://你的域名

# 是否允许自助注册（生产环境建议 false，仅首账号可依赖首次 allow 或临时开启）
ALLOW_REGISTRATION=false

# 反代已启 HTTPS 时建议 true
SESSION_HTTPS_ONLY=false
